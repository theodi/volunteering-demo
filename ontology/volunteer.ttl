    skos:prefLabel "Practical Skills"@en .

vp:Technology a skos:Concept ;
    skos:prefLabel "Technology"@en .

vp:LocalKnowledge a skos:Concept ;
    skos:prefLabel "Local Knowledge"@en .

vp:SkillsScheme a skos:ConceptScheme ;
    skos:hasTopConcept vp:PersonalQualities ;
    skos:hasTopConcept vp:Communication ;
    skos:hasTopConcept vp:Teamwork ;
    skos:hasTopConcept vp:SafetyAndAwareness ;
    skos:hasTopConcept vp:PracticalSkills ;
    skos:hasTopConcept vp:Technology ;
    skos:hasTopConcept vp:LocalKnowledge .

