# Emergency causes
vp:DisasterRelief a skos:Concept ;
    skos:prefLabel "Disaster Relief"@en ;
    skos:broader vp:Emergency .
vp:EmergencyResponse a skos:Concept ;
    skos:prefLabel "Emergency Response"@en ;
