# =============================================================================
# Requirements / Equipment & Resources (by category)
# =============================================================================

# Categories
vp:PhysicalAndPersonal a skos:Concept ;
    skos:prefLabel "Physical & Personal"@en .

vp:Clothing a skos:Concept ;
    skos:prefLabel "Clothing"@en .

vp:Equipment a skos:Concept ;
    skos:prefLabel "Equipment"@en .

vp:Vehicles a skos:Concept ;
    skos:prefLabel "Vehicles"@en .

vp:Facilities a skos:Concept ;
    skos:prefLabel "Facilities"@en .

# Concept scheme: defines which categories are "equipment/requirements" (single source of truth)
vp:EquipmentRequirements a skos:ConceptScheme ;
    skos:hasTopConcept vp:PhysicalAndPersonal ;
    skos:hasTopConcept vp:Clothing ;
    skos:hasTopConcept vp:Equipment ;
    skos:hasTopConcept vp:Vehicles ;
    skos:hasTopConcept vp:Facilities .

# Physical & Personal
vp:PhysicalStamina a skos:Concept ;
    skos:prefLabel "Physical Stamina"@en ;
    skos:broader vp:PhysicalAndPersonal .
vp:AbilityToWorkOutdoors a skos:Concept ;
    skos:prefLabel "Ability to Work Outdoors"@en ;
    skos:broader vp:PhysicalAndPersonal .
vp:PersonalPreparedness a skos:Concept ;
    skos:prefLabel "Personal Preparedness"@en ;
    skos:broader vp:PhysicalAndPersonal .

# Clothing
vp:SturdyFootwear a skos:Concept ;
    skos:prefLabel "Sturdy Footwear"@en ;
    skos:broader vp:Clothing .
vp:WaterproofsAndWarmLayers a skos:Concept ;
    skos:prefLabel "Waterproofs and Warm Layers"@en ;
    skos:broader vp:Clothing .
vp:Gloves a skos:Concept ;
    skos:prefLabel "Gloves"@en ;
    skos:broader vp:Clothing .
vp:HighVisibilityVest a skos:Concept ;
    skos:prefLabel "High-Visibility Vest"@en ;
    skos:broader vp:Clothing .

